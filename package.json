{
    "name": "aris-chrome-exoskeleton",
    "version": "0.3.1",
    "description": "Ari's Chrome exoskeleton with reusable library, testing, and CI/CD",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -p tsconfig.build.json && vite build",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage",
        "test-handler-html": "tsx src/exo-tabs/richlink/handlers/test-with-html.ts",
        "parse-html": "tsx src/exo-tabs/richlink/handlers/parse-html.ts",
        "test-autoscroll": "tsx scripts/test-autoscroll-detection.ts",
        "lint": "eslint . --ext ts,tsx",
        "lint:fix": "eslint . --ext ts,tsx --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
        "test:e2e": "npm run build && npx playwright test",
        "test:e2e:headed": "npm run build && npx playwright test --headed",
        "test:e2e:ui": "npm run build && npx playwright test --ui",
        "zip": "npm run build && cd dist && zip -r ../extension.zip . && cd ..",
        "bump": "commit-and-tag-version",
        "bump:patch": "commit-and-tag-version --release-as patch",
        "bump:minor": "commit-and-tag-version --release-as minor",
        "bump:major": "commit-and-tag-version --release-as major"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "dependencies": {
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@crxjs/vite-plugin": "^2.3.0",
        "@eslint/js": "^9.0.0",
        "@playwright/test": "^1.58.2",
        "@testing-library/jest-dom": "^6.6.0",
        "@testing-library/react": "^16.0.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/chrome": "^0.0.280",
        "@types/jsdom": "^27.0.0",
        "@types/node": "^25.2.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "@vitest/coverage-v8": "^4.0.17",
        "@vitest/ui": "^4.0.0",
        "commit-and-tag-version": "^12.6.1",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.37.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "jsdom": "^25.0.0",
        "prettier": "^3.4.0",
        "sinon-chrome": "^3.0.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.0",
        "vite": "^7.0.0",
        "vitest": "^4.0.0"
    },
    "license": "MIT"
}
